{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created"
        }
      },
      "required": ["email", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A contact uploaded by the user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pending", "keep", "bin", "meet", "park", "priority"]
        },
        "met": { "type": "boolean" },
        "notes": { "type": "string" },
        "sourceFile": { "type": "string" },
        "originalData": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/users/{userId}/contacts/{contactId}": {
      "schema": { "$ref": "#/entities/Contact" },
      "description": "Contacts belonging to a user"
    }
  }
}
